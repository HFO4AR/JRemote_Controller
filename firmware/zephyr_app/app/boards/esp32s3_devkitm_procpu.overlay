/*
 * JRemote Controller - 设备树覆盖层
 * WS2812 LED SPI 配置
 * UART MCU 通信配置
 */

#include <zephyr/dt-bindings/led/led.h>

&spi3 {
	/* WS2812 驱动支持 */
	line-idle-low;

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";

		/* SPI 配置 */
		reg = <0>;
		spi-max-frequency = <6400000>;

		/* WS2812 配置 */
		chain-length = <1>;
		spi-cpha;
		spi-one-frame = <0xf0>;  /* 11110000: 625ns 高电平 + 625ns 低电平 */
		spi-zero-frame = <0xc0>;  /* 11000000: 312.5ns 高电平 + 937.5ns 低电平 */
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
	};
};

&pinctrl {
	spim3_default: spim3_default {
		group1 {
			pinmux = <SPIM3_MOSI_GPIO48>;
		};
	};
	uart1_default: uart1_default {
		group1 {
			pinmux = <UART1_TX_GPIO17>;
			output-high;
		};
		group2 {
			pinmux = <UART1_RX_GPIO18>;
			bias-pull-up;
		};
	};
};

/* MCU 通信 UART */
&uart1 {
	status = "okay";
	current-speed = <115200>;

	pinctrl-0 = <&uart1_default>;
	pinctrl-names = "default";
};

/ {
	aliases {
		led-strip = &led_strip;
	};
};
